{
  "name": "video-editor-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "echo 'No host build needed - container image built by wrangler deploy'",
    "deploy": "npm run build-image && npm run push-image && wrangler deploy",
    "build-image": "wrangler containers build . -t video-editor:latest",
    "push-image": "wrangler containers push video-editor:latest",
    "dev": "wrangler dev"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.0"
  },
  "devDependencies": {
    "wrangler": "^4.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
